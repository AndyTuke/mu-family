// Custom VERSIONINFO for μ-Tant.
// Included via JUCE_USER_DEFINED_RC_FILE — replaces JUCE's auto-generated block.
// #pragma code_page(65001) is set in the including file so UTF-8 strings work here.

#undef  WIN32_LEAN_AND_MEAN
#define WIN32_LEAN_AND_MEAN
#include <windows.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION  @MUFAMILY_FILEVERSION@
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904E4"
    BEGIN
      VALUE "CompanyName",    "Transwarp Development Project\0"
      VALUE "LegalCopyright", "@MUFAMILY_COPYRIGHT@\0"
      VALUE "FileDescription","μ-Tant\0"
      VALUE "FileVersion",    "@MUFAMILY_PLUGIN_VERSION@\0"
      VALUE "ProductName",    "μ-Tant\0"
      VALUE "ProductVersion", "@MUFAMILY_PLUGIN_VERSION@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1252
  END
END
