<?xml version='1.0' encoding='utf-8'?>
<MuClidPreset presetName="A9_base" presetDescription="Single-rhythm hot-swap test A9: base preset is a kick on every beat with a 2s master loop (mstrLoop=1). A per-rhythm swap (stageRhythmPreset) replaces slot 0 with a hat mid-play; it must defer to the 2s master boundary, then the rendered content changes from low-frequency (kick) to high-frequency (hat). Exercises the per-rhythm staging path (HotSwapStager pendingSwaps), distinct from A1's full-preset load." presetCategory="test">
  <Rhythm name="A9-Kick" colour="1" sample="Kick 01.wav" stepsA="16" hitsA="4" rotA="0" prePadA="0" postPadA="0" insStA="0" insLenA="0" insModeA="false" prePadModeA="false" postPadModeA="false" stepsB="8" hitsB="0" rotB="0" prePadB="0" postPadB="0" insStB="0" insLenB="0" insModeB="false" prePadModeB="false" postPadModeB="false" stepsC="8" hitsC="0" rotC="0" prePadC="0" postPadC="0" insStC="0" insLenC="0" insModeC="false" prePadModeC="false" postPadModeC="false" logic="OR" pitchOct="0" pitchSemi="0" pitchFine="0" fltType="LP12" fltCut="20000" fltRes="0" ampLvl="1.0" aEnvAtk="0.001" aEnvDec="0.18" aEnvSus="0" aEnvRel="0.08" aEnvLeg="false" accentDb="0" drvChar="None" ch_lvl="0.85" ch_pan="0.5" ch_mute="0.0" ch_solo="0.0" ch_sendEff="0.0" ch_sendDly="0.0" ch_sendRev="0.0" ch_scSrc="0.0" ch_scAmt="0.0" ch_outBus="0.0"/>
  <GlobalState mstrLoop="1"/>
</MuClidPreset>
